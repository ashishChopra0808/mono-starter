{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["mono-starter"],
    "baseUrl": ".",
    "paths": {
      "@mono/ui-web": ["packages/ui-web/src/index.ts"],
      "@mono/ui-mobile": ["packages/ui-mobile/src/index.ts"],
      "@mono/design-tokens": ["packages/design-tokens/src/index.ts"],
      "@mono/design-tokens/css": ["packages/design-tokens/src/css.ts"],
      "@mono/design-tokens/native": ["packages/design-tokens/src/native.ts"],
      "@mono/i18n": ["packages/i18n/src/index.ts"],
      "@mono/types": ["packages/types/src/index.ts"],
      "@mono/validation": ["packages/validation/src/index.ts"],
      "@mono/auth": ["packages/auth/src/index.ts"],
      "@mono/db": ["packages/db/src/index.ts"],
      "@mono/db/schema": ["packages/db/src/schema/index.ts"],
      "@mono/db/client": ["packages/db/src/client.ts"],
      "@mono/logger": ["packages/logger/src/index.ts"],
      "@mono/logger/node": ["packages/logger/src/node.ts"],
      "@mono/api-contracts": ["packages/api-contracts/src/index.ts"],

      "@mono/env": ["packages/env/src/index.ts"],
      "@mono/env/web": ["packages/env/src/web.ts"],
      "@mono/env/admin": ["packages/env/src/admin.ts"],
      "@mono/env/api": ["packages/env/src/api.ts"],
      "@mono/env/mobile": ["packages/env/src/mobile.ts"]
    }
  }
}
