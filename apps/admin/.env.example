# ─── Admin App Environment Variables ─────────────────────────────────────────
# Copy this file to .env.local and fill in the values.

# Server-side only (never exposed to the browser)
NODE_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/mono_starter
JWT_SECRET=change-me-to-a-32-character-minimum-secret-key
# REDIS_URL=redis://localhost:6379

# Client-side (embedded in the browser bundle via NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_APP_URL=http://localhost:4300
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_ADMIN_ROLE=admin
