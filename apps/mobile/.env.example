# ─── Mobile App Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in the values.
# Note: EXPO_PUBLIC_ variables are embedded in the JS bundle at build time.
# Do NOT put secrets here — they will be visible to anyone with the app.

EXPO_PUBLIC_API_URL=http://localhost:3000/api
EXPO_PUBLIC_APP_NAME=MonoStarter
