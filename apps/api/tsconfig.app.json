{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "module": "nodenext",
    "types": ["node"],
    "rootDir": "src",
    "moduleResolution": "nodenext",
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "es2021",
    "paths": {
      "@mono/auth": ["packages/auth/src/index.ts"],
      "@mono/env/api": ["packages/env/dist/api.d.ts"],
      "@mono/logger/node": ["packages/logger/dist/node.d.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.spec.ts", "src/**/*.test.ts"],
  "references": [
    {
      "path": "../../packages/validation/tsconfig.lib.json"
    },
    {
      "path": "../../packages/logger/tsconfig.lib.json"
    },
    {
      "path": "../../packages/env/tsconfig.lib.json"
    },
    {
      "path": "../../packages/db/tsconfig.lib.json"
    },
    {
      "path": "../../packages/api-contracts/tsconfig.lib.json"
    },
    {
      "path": "../../packages/auth/tsconfig.lib.json"
    }
  ]
}
