{
  "name": "@mono/api-client",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "mono-starter": "./src/index.ts",
      "types": "./dist/index.d.ts",
