{
  "name": "@mono/design-tokens",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "mono-starter": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./css": {
      "mono-starter": "./src/css.ts",
      "types": "./dist/css.d.ts",
      "import": "./dist/css.js",
      "default": "./dist/css.js"
    },
    "./native": {
      "mono-starter": "./src/native.ts",
      "types": "./dist/native.d.ts",
      "import": "./dist/native.js",
      "default": "./dist/native.js"
    }
  },
  "dependencies": {
    "tslib": "^2.3.0"
  }
}
