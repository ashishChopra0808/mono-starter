# ─── Shared ──────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/mono_starter

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-32-character-minimum-secret-key

# ─── Redis (optional) ───────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ─── API ─────────────────────────────────────────────────────────────────────
PORT=3000
CORS_ORIGINS=http://localhost:4200,http://localhost:4300

# ─── Web (Next.js) ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:4200
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ─── Admin (Next.js) ────────────────────────────────────────────────────────
# Uses same NEXT_PUBLIC_APP_URL / NEXT_PUBLIC_API_URL — set per deployment
# NEXT_PUBLIC_ADMIN_ROLE=admin

# ─── Mobile (Expo) ──────────────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:3000/api
EXPO_PUBLIC_APP_NAME=MonoStarter
