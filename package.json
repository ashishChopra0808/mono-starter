{
  "name": "mono-starter",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "nx run-many -t dev",
    "build": "nx run-many -t build",
    "lint": "nx run-many -t lint",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,jsx,json,md,css,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,jsx,json,md,css,yml,yaml}\"",
    "test": "nx run-many -t test",
    "typecheck": "nx run-many -t typecheck"
  },
