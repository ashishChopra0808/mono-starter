    "@mono/config-prettier": "workspace:*",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@next/eslint-plugin-next": "^16.2.1",
    "@nx/devkit": "22.6.3",
    "@nx/eslint": "^22.6.3",
    "@nx/expo": "22.6.3",
    "@nx/js": "22.6.3",
    "@nx/nest": "22.6.3",
    "@nx/next": "22.6.3",
    "@nx/node": "22.6.3",
    "@nx/playwright": "22.6.3",
    "@nx/web": "22.6.3",
    "@nx/webpack": "22.6.3",
    "@playwright/test": "^1.36.0",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
