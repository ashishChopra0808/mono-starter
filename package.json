    "@types/node": "20.19.9",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.0.0",
    "babel-preset-expo": "~54.0.7",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.4.0",
    "metro-config": "~0.83.0",
    "metro-resolver": "~0.83.0",
    "nx": "22.6.3",
